# Copy this file to .env and fill in real values.
# .env is gitignored — never commit your actual secrets.

# --- VPN (custom WireGuard provider) ---
VPN_ENDPOINT_IP=216.0.176.14
VPN_ENDPOINT_PORT=64459
VPN_PUBLIC_KEY=your_wireguard_public_key
VPN_PRIVATE_KEY=your_wireguard_private_key
VPN_INTERFACE_IP=10.4.1.4
VPN_FORWARDED_PORT=64459
LOCAL_SUBNET_RANGE=192.168.1.0/24

# --- General ---
TIMEZONE=America/New_York

# --- Samba users ---
CHIEF_PASSWORD=change_me
FAMILY_PASSWORD=change_me
